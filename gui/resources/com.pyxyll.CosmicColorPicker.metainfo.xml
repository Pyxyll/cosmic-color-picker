  <releases>
    <release version="0.2.0" date="2026-05-09">
      <description>
        <p>First tagged release.</p>
        <ul>
          <li>Two-binary architecture: long-running daemon + GUI + panel applet</li>
          <li>Native ext-image-copy-capture-v1 capture (no external grim dependency)</li>
          <li>HEX, RGB, HSL, HSV, OKLCH format readouts with per-row copy</li>
          <li>Recents history persisted via cosmic-config</li>
          <li>Configurable system-wide hotkey + autostart toggle</li>
          <li>Panel applet pop-up</li>
          <li>Pick-entry animations on hero swatch and new recents chip</li>
        </ul>
      </description>
      <url>https://github.com/Pyxyll/cosmic-color-picker/releases/tag/v0.2.0</url>
    </release>
  </releases>
</component>
