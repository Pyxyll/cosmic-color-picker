<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.pyxyll.CosmicColorPicker</id>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <project_group>COSMIC</project_group>

  <name>Color Picker</name>
  <summary>Native Wayland color picker for COSMIC</summary>

  <developer id="com.pyxyll">
    <name>pyxyll</name>
  </developer>
  <update_contact>pyxyllv@gmail.com</update_contact>

  <description>
    <p>
      A native Wayland color picker for the COSMIC desktop. Press your hotkey
      to summon a magnifier-on-cursor overlay with pixel-precision sampling,
      then have the color delivered to your clipboard alongside HEX, RGB, HSL,
      HSV, and OKLCH readouts.
    </p>
    <p>Features:</p>
    <ul>
      <li>System-wide hotkey, configurable from the Settings page</li>
      <li>Recents history with one-click re-copy</li>
      <li>HEX, RGB, HSL, HSV, and OKLCH format readouts</li>
      <li>Panel applet for picking without opening the GUI</li>
      <li>A long-running daemon owns the overlay, clipboard, and history so the hotkey works whether or not the GUI is open</li>
    </ul>
  </description>

  <url type="homepage">https://github.com/Pyxyll/cosmic-color-picker</url>
  <url type="bugtracker">https://github.com/Pyxyll/cosmic-color-picker/issues</url>
  <url type="vcs-browser">https://github.com/Pyxyll/cosmic-color-picker</url>

  <launchable type="desktop-id">com.pyxyll.CosmicColorPicker.desktop</launchable>

  <provides>
    <binary>cosmic-color-picker</binary>
    <binary>cosmic-color-pickerd</binary>
    <binary>cosmic-applet-color-picker</binary>
  </provides>

  <categories>
    <category>Utility</category>
    <category>Graphics</category>
  </categories>

  <keywords>
    <keyword>color</keyword>
    <keyword>picker</keyword>
    <keyword>hex</keyword>
    <keyword>rgb</keyword>
    <keyword>hsl</keyword>
    <keyword>oklch</keyword>
    <keyword>cosmic</keyword>
  </keywords>

  <branding>
    <color type="primary" scheme_preference="light">#EC4899</color>
    <color type="primary" scheme_preference="dark">#1E293B</color>
  </branding>

  <content_rating type="oars-1.1" />

  <screenshots>
