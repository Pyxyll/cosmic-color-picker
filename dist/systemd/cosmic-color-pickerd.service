[Unit]
Description=COSMIC color-picker daemon
Documentation=https://github.com/Pyxyll/cosmic-color-picker
PartOf=graphical-session.target
After=graphical-session.target

[Service]
Type=simple
ExecStart=/usr/bin/cosmic-color-pickerd
Restart=on-failure
RestartSec=5
# Crash logs land in journalctl --user -u cosmic-color-pickerd
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=graphical-session.target
